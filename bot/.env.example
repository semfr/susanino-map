# Скопируй этот файл в .env и впиши реальные значения.
# .env НЕ коммитится (см. .gitignore). На сервере держи права 600.

# Токен Telegram-бота (получить у @BotFather)
BOT_TOKEN=123456789:replace-with-real-token

# Необязательно: путь к данным. По умолчанию ../data относительно папки bot/.
# DATA_DIR=/opt/susanino-map/data

# --- Админка через бота (часть B) ---

# Telegram-id админов через запятую. Пусто = админка недоступна никому.
ADMIN_IDS=

# Fine-grained PAT, scope Contents:RW ТОЛЬКО на semfr/susanino-map (без workflows).
# Нужен для публикации правок в канон data/objects.json. Пусто = публикация выключена.
GITHUB_TOKEN=

# Базовый URL сайта (GitHub Pages). По умолчанию https://semfr.github.io/susanino-map.
SITE_BASE_URL=

# --- Необязательно (есть дефолты в config.py) ---
# GITHUB_REPO=semfr/susanino-map
# GITHUB_BRANCH=master
# DATA_FILE_IN_REPO=data/objects.json
# BOT_USERNAME=susanino_map_bot
